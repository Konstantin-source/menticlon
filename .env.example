# ==============================================================================
# VibePoll Configuration Template
# Copy this file to '.env' and fill in your actual values.
# DO NOT commit the '.env' file to your version control system.
# ==============================================================================

# Application environment (development / production)
NODE_ENV=production

# Ports to expose on the host machine
BACKEND_PORT=5000
FRONTEND_PORT=80

# PostgreSQL Configuration
POSTGRES_USER=vibepoll_admin
POSTGRES_PASSWORD=choose_a_strong_database_password
POSTGRES_DB=vibepoll
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Combined connection string used by the backend
DATABASE_URL=postgres://vibepoll_admin:choose_a_strong_database_password@postgres:5432/vibepoll

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=choose_a_strong_redis_password

# Cloudflare Tunnel Configuration
# Obtain this token from your Cloudflare Zero Trust Dashboard (Tunnels page)
TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# Frontend Environment Variables (Injected during Docker build)
# Set these to the public domain name where your app is hosted
VITE_API_URL=https://menti.konstihome.de
VITE_WS_URL=wss://menti.konstihome.de

